# The checked-in default is a no-value simulation. No Solana RPC calls are made.
PAYMENT_MODE=simulation
GAME_HOST=127.0.0.1
GAME_PORT=5190
PUBLIC_ORIGIN=http://127.0.0.1:5188
QUESTION_PRICE_LAMPORTS=10000000
INITIAL_TURNS=20
PLATFORM_FEE_BPS=0
GAME_DATA_FILE=.data/game.json

# Required server-side AI referee. Startup fails unless this key passes a live readiness probe.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-sol

# Mainnet-only settings. The mnemonic is loaded only by the Node server.
# Never prefix it with VITE_ and never expose it to browser code.
MAINNET_TRANSACTIONS_ENABLED=false
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_TREASURY_MNEMONIC=
SOLANA_TREASURY_DERIVATION_PATH=m/44'/501'/0'/0'
# Optional assertion: startup fails if this does not match the derived address.
SOLANA_TREASURY_ADDRESS=
